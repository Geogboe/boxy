#!/usr/bin/env bash
# Code generated by go generate; DO NOT EDIT.
# {{.BinaryName}} installer — Linux & macOS
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/{{.Repo}}/main/scripts/install.sh | bash
#
# Environment variables:
#   BOXY_VERSION     Pin a specific version (e.g. v0.2.0). Defaults to latest release.
#   BOXY_INSTALL_DIR Override install directory. Defaults to $HOME/{{.DefaultInstallDir}}.
#   BOXY_DEBUG       Set to 1 for verbose output.
#   BOXY_FORCE       Set to 1 to overwrite an existing binary.

set -eu
# pipefail is a bash/zsh extension; enable it when available, ignore otherwise.
# shellcheck disable=SC3040
if (set -o pipefail) 2>/dev/null; then set -o pipefail; fi

REPO="{{.Repo}}"
BINARY="{{.BinaryName}}"
INSTALL_DIR="${BOXY_INSTALL_DIR:-${HOME}/{{.DefaultInstallDir}}}"
TMPDIR_CLEANUP=""

if [ -t 2 ]; then
    RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m' BLUE='\033[0;34m' BOLD='\033[1m' NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' BOLD='' NC=''
fi

info()  { printf "${BLUE}==>${NC} ${BOLD}%s${NC}\n" "$*" >&2; }
ok()    { printf "${GREEN}✓${NC} %s\n" "$*" >&2; }
warn()  { printf "${YELLOW}warning:${NC} %s\n" "$*" >&2; }
error() { printf "${RED}error:${NC} %s\n" "$*" >&2; exit 1; }
debug() { [ "${BOXY_DEBUG:-}" = "1" ] && printf "${BLUE}[debug]${NC} %s\n" "$*" >&2 || true; }

detect_os() {
    case "$(uname -s)" in
        Linux*)  echo "linux" ;;
        Darwin*) echo "darwin" ;;
        *)       error "unsupported OS: $(uname -s)" ;;
    esac
}

detect_arch() {
    case "$(uname -m)" in
        x86_64|amd64)  echo "amd64" ;;
        aarch64|arm64) echo "arm64" ;;
        *)             error "unsupported architecture: $(uname -m)" ;;
    esac
}

resolve_version() {
    if [ -n "${BOXY_VERSION:-}" ]; then
        debug "Using pinned version: ${BOXY_VERSION}"
        echo "${BOXY_VERSION}"
        return
    fi

    info "Fetching latest release version..."
    local api_base="${BOXY_BASE_URL:-{{.APIBase}}}"
    local version
    version="$(curl -fsSL "${api_base}/repos/${REPO}/releases?per_page=1" \
        | grep '"tag_name"' | head -1 | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')"
    [ -n "${version}" ] || error "Could not determine latest version."
    echo "${version}"
}

checksum_file() {
    local file="$1"
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$file" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$file" | awk '{print $1}'
    else
        error "sha256sum or shasum is required"
    fi
}

check_path() {
    local dir="$1"
    case ":${PATH}:" in
        *":${dir}:"*) return ;;
    esac

    warn "${dir} is not in your PATH."
    local shell_name
    shell_name="$(basename "${SHELL:-sh}")"
    case "${shell_name}" in
        zsh)
            printf "  Add it with: %s\n" "echo 'export PATH=\"${dir}:\$PATH\"' >> ~/.zshrc" >&2
            ;;
        fish)
            printf "  Add it with: %s\n" "set -U fish_user_paths ${dir} \$fish_user_paths" >&2
            ;;
        *)
            printf "  Add it with: %s\n" "echo 'export PATH=\"${dir}:\$PATH\"' >> ~/.bashrc" >&2
            ;;
    esac
}

main() {
    command -v curl >/dev/null 2>&1 || error "curl is required"

    local os arch version version_num archive
    os="$(detect_os)"
    arch="$(detect_arch)"
    info "Detected platform: ${os}/${arch}"

    version="$(resolve_version)"
    info "Installing ${BINARY} ${version}"

    version_num="${version#v}"
    archive="${BINARY}_${version_num}_${os}_${arch}.tar.gz"

    local download_base="${BOXY_BASE_URL:-{{.DownloadBase}}}/${REPO}/releases/download/${version}"

    local tmp_dir
    tmp_dir="$(mktemp -d)"
    TMPDIR_CLEANUP="${tmp_dir}"
    trap 'rm -rf "${TMPDIR_CLEANUP}"' EXIT

    debug "version=${version} install_dir=${INSTALL_DIR} archive=${archive}"
    debug "download_base=${download_base}"

    info "Downloading ${archive}..."
    curl -fsSL "${download_base}/${archive}" -o "${tmp_dir}/${archive}" \
        || error "Failed to download ${archive}"

    info "Downloading checksums.txt..."
    curl -fsSL "${download_base}/checksums.txt" -o "${tmp_dir}/checksums.txt" \
        || error "Failed to download checksums.txt"

    info "Verifying checksum..."
    local expected actual
    expected="$(awk -v asset="${archive}" '$2 == asset { print $1 }' "${tmp_dir}/checksums.txt")"
    [ -n "${expected}" ] || error "Checksum for ${archive} not found in checksums.txt"
    actual="$(checksum_file "${tmp_dir}/${archive}")"
    [ "${expected}" = "${actual}" ] || error "Checksum mismatch for ${archive}"
    ok "Checksum verified"

    info "Installing to ${INSTALL_DIR}..."
    mkdir -p "${INSTALL_DIR}"

    local dest="${INSTALL_DIR}/${BINARY}"
    if [ -e "${dest}" ] && [ "${BOXY_FORCE:-}" != "1" ]; then
        error "${dest} already exists. Set BOXY_FORCE=1 to overwrite."
    fi

    tar -xzf "${tmp_dir}/${archive}" -C "${tmp_dir}" "${BINARY}"
    install -m 0755 "${tmp_dir}/${BINARY}" "${dest}"

    ok "${BINARY} ${version} installed to ${dest}"
    check_path "${INSTALL_DIR}"
    printf "Run '%s --help' to get started.\n" "${BINARY}" >&2
}
main "$@"
