{
  "$id": "boxy://schemas/boxy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "providers": {
      "items": {
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "docker"
                }
              }
            },
            "then": {
              "properties": {
                "config": {
                  "$ref": "providers/docker.config.schema.json"
                }
              }
            }
          }
        ],
        "properties": {
          "config": {
            "type": "object"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "type": {
            "enum": [
              "docker"
            ],
            "type": "string"
          }
        },
        "required": [
          "name",
          "type"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "title": "Boxy Configuration",
  "type": "object"
}
